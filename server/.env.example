# Copy this file to `.env` and fill in your key.
# Without a key the server runs in MOCK mode (canned STT/LLM, browser TTS) so you can
# demo the full loop with zero cost. Add a key to switch to real Sarvam AI.

# Get one at https://dashboard.sarvam.ai
SARVAM_API_KEY=

# Optional overrides
PORT=3001
SARVAM_STT_MODEL=saaras:v3
SARVAM_LLM_MODEL=sarvam-30b
SARVAM_TTS_MODEL=bulbul:v2
